    <projectnotes visible="0" x="102" maximized="0" y="700" height="300" width="725"><![CDATA[<!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.0//EN" "http://www.w3.org/TR/REC-html40/strict.dtd">
