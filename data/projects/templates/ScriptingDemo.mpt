<p style=" margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;"><span style=" font-family:'Sans Serif'; font-size:9pt; color:#e0e0e0;">Put down your project notes here.</span></p></body></html>]]></projectnotes>
    <scriptwindow visible="1" x="628" maximized="0" y="360" height="865" width="830"><![CDATA[from lmms import *

# 192 ticks per bar; quarter = 48, eighth = 24, sixteenth = 12

def note(key, pos, length=24, vol=100, pan=0):
    return {'key': key, 'pos': pos, 'len': length, 'vol': vol, 'pan': pan}

# Clear tracks 0-4
for i in range(5):
    clearTrack(i)

# --- Melody (track 0): C major scale, 8 eighth notes ---
melody_clip = appendClip(0)
melody_notes = [72, 74, 76, 77, 79, 81, 83, 84]  # C5 to C6
for i, key in enumerate(melody_notes):
    addToClip(melody_clip, note(key, pos=i * 24, length=24))

# --- Bass (track 1): root-fifth, 4 quarter notes ---
bass_clip = appendClip(1)
bass_notes = [36, 43, 36, 43]  # C2, G2, C2, G2
for i, key in enumerate(bass_notes):
    addToClip(bass_clip, note(key, pos=i * 48, length=48))

# --- Kick (track 2): beats 1 and 3 ---
kick_clip = appendClip(2)
for pos in [0, 96]:
    addToClip(kick_clip, note(69, pos=pos, length=12))

# --- Snare (track 3): beats 2 and 4 ---
snare_clip = appendClip(3)
for pos in [48, 144]:
    addToClip(snare_clip, note(69, pos=pos, length=12))

# --- Hi-hat (track 4): every eighth note ---
hihat_clip = appendClip(4)
for i in range(8):
    addToClip(hihat_clip, note(69, pos=i * 24, length=12))]]></scriptwindow>
